                    <div class="card-header">
                        <h3 class="card-title">Liste des stages de <span class="text-primary">{{ candidate.getFirstName() }}</span></h3>
                    </div>
                    <div class="card-body p-0">
                        {{ include('back/partials/tables/candidate/_internships.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
    
{% endblock %}

