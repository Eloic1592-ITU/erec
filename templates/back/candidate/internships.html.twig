{# ---------------------------- Layout ---------------------------- #}
{% extends 'back/layouts/base.html.twig' %}

{# ---------------------------- Title ---------------------------- #}
{% block title %}
    Dashboard | Diplôme académiques
{% endblock %}

{# ---------------------------- CSS ---------------------------- #}
{% block stylesheets %}
  <link rel="stylesheet" href="{{ asset('css/back/user.css') }}" />
{% endblock %}

{# ---------------------------- Body ---------------------------- #}
{% block body %}
    
    {{ include('back/partials/_header.html.twig') }}

    <div class="container">
        <div class="row">
            <div class="col-lg-12">
