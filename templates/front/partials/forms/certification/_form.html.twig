<div class="my-4 certification-form">
    {{ form_start(form, {
        'attr': {
            'id': 'certification-' ~ form.vars.value.id,
            'class': 'needs-validation',
            'novalidate': '',
            'data-edit-url': certification_edit_url,
            'data-delete-url': certification_delete_url,
        }
    }) }}
        
        <div class="row">
            <div class="col-lg-12">
                <div class="mb-3">
                    {{ form_label(form.certification) }} <span class="star">*</span>
                    {{ form_widget(form.certification) }}
                    {{ form_errors(form.certification) }}
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="mb-3">
                    {{ form_label(form.certificationFile) }} <span class="star">*</span>
                    {{ form_widget(form.certificationFile) }}
                    {{ form_errors(form.certificationFile) }}
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="mb-3">
                    {{ form_label(form.specialty) }} <span class="star">*</span>
                    {{ form_widget(form.specialty) }}
                    {{ form_errors(form.specialty) }}
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <div class="mb-3">
                    {{ form_label(form.institution) }} <span class="star">*</span>
                    {{ form_widget(form.institution) }}
                    {{ form_errors(form.institution) }}
                </div>
            </div>
            <div class="col-lg-6">
                <div class="mb-3">
                    {{ form_label(form.certification_year) }} <span class="star">*</span>
                    {{ form_widget(form.certification_year) }}
                    {{ form_errors(form.certification_year) }}
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <button 
                type="submit" 
                class="btn btn-primary d-flex align-items-center gap-1"
            >
                <i class="bx bx-edit"></i> 
                <span class="d-none d-lg-flex">Mettre à jour cette certification / attestation</span>
            </button>
            <button 
                type="button" 
                class="btn btn-danger d-flex align-items-center gap-1 delete-certification" 
                data-id="{{ certification.id }}" 
                data-url="{{ path('app_certification_delete', {'id': certification.id}) }}"
            >
                <i class="bx bx-trash"></i> 
                <span class="d-none d-lg-flex">Supprimer cette certification / attestation</span>
            </button>
        </div>

    {{ form_end(form) }}
</div>
