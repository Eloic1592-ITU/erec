{# ---------------------------- Layout ---------------------------- #}
{% extends 'back/layouts/base.html.twig' %}

{# ---------------------------- Title ---------------------------- #}
{% block title %}
    Dashboard | Diplôme académiques
{% endblock %}

{# ---------------------------- CSS ---------------------------- #}
{% block stylesheets %}
  <link rel="stylesheet" href="{{ asset('css/inforecap.css') }}" />
{% endblock %}

{# ---------------------------- Body ---------------------------- #}
{% block body %}
    
    {{ include('back/partials/_header.html.twig') }}

    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Niveau de langue</h3>
                    </div>
                    <div class="card-body p-0">
                        {{ include('back/partials/tables/candidate/_skills_language.html.twig') }}
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Compétences en Tech Microsoft</h3>
                    </div>
                    <div class="card-body p-0">
                        {{ include('back/partials/tables/candidate/_skills_microsoft.html.twig') }}
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Autres compétences informatiques</h3>
                    </div>
                    <div class="card-body p-4">
                        {{ include('back/partials/tables/candidate/_skills_other.html.twig') }}
                    </div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Autres compétences non informatiques</h3>
                    </div>
                    <div class="card-body p-4">
                        {% if candidate.otherInfo.otherNotInfoSkills is defined and candidate.otherInfo.otherNotInfoSkills is not empty %}
                            <div class="tags">
                                {% for skillOth in candidate.otherInfo.otherNotInfoSkills|split(',') %}
                                    <span class="tag">{{ skillOth }}</span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    
{% endblock %}

{# ---------------------------- JS ---------------------------- #}
{% block javascripts %}
  {# ... #}
{% endblock %}

