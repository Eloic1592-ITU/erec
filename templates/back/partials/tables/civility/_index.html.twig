<table id="data-list" class="table table-striped nowrap" style="width: 100%">
    <thead>
    <tr>
        <th>ID</th>
        <th>Nom</th>
        <th>Statut</th>
        <th>Actions</th>
        <th>Détails</th>
    </tr>
    </thead>
    <tbody>
    {% for civility in civilities %}
        <tr>
            <td>{{ civility.getId() }}</td>
            <td>{{ civility.getName() }}</td>
            <td>
                {% if not civility.isDeleted() %}
                    <span class="badge text-bg-success rounded-pill">Activé</span> 
                {% else %}
                    <span class="badge text-bg-danger rounded-pill">Desactivé</span>
                {% endif %}
            </td>
            <td>
                <div class="d-flex justify-content-end gap-1">
                    <button 
                        class="btn-action bg-warning" 
                        data-bs-toggle="modal" 
                        data-bs-target="#civility-{{ civility.getId() }}"
                    >
                        <i class="bx bx-edit"></i> 
                        <span>Modifier</span>
                    </button>

                    {% if not civility.isDeleted() %}
                        <button 
                            class="btn-action btn-state bg-danger delete-civility"
                            data-state="désactiver cette civilité" 
                            data-url="{{ path('admin_civility_disable', {'id': civility.getId()}) }}"
                        >
                            <span>Désactiver</span>
                        </button>
                    {% else %}
                        <button 
                            class="btn-action btn-state bg-success delete-civility"
                            data-state="réactiver cette civilité" 
                            data-url="{{ path('admin_civility_activate', {'id': civility.getId()}) }}"
                        >
                            <span>Activer</span>
                        </button>
                    {% endif %}
                </div>
            </td>
            <td><a class='btn btn-warning btn-sm bg-warning text-white w-100' href='#'><i class='bx bx-info-circle me-2'></i>Voir plus</a></td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{# Modal for Adding new item #}
{{ include('back/partials/modals/_newCivility.html.twig') }}

{# Modals for Editing each items #}
{% for civilityForm in civilityForms %}
    {{ include('back/partials/modals/_editCivility.html.twig') }}
{% endfor %}