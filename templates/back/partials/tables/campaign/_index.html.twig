<table id="data-list" class="table table-striped nowrap" style="width: 100%">
    <thead>
    <tr>
        <th>ID</th>
        <th>Titre</th>
        <th>Description</th>
        <th>Statut</th>
        <th>Actions</th>
        <th>Détails</th>
    </tr>
    </thead>
    <tbody>
    {% for campaign in campaigns %}
        <tr>
            <td>{{ campaign.getId() }}</td>
            <td>{{ campaign.getTitle() }}</td>
            <td>{{ campaign.getDescription() }}</td>
            <td>
                {% if not campaign.isDeleted() %}
                    <span class="badge text-bg-success rounded-pill">Activé</span> 
                {% else %}
                    <span class="badge text-bg-danger rounded-pill">Desactivé</span>
                {% endif %}
            </td>
            <td>
                <div class="d-flex justify-content-end gap-1">
                    <button 
                        class="btn-action bg-primary" 
                        data-bs-toggle="modal" 
                        data-url="#"
                    >
                     <a class="nav-link" href="{{ path('admin_position_per_campaign', {'id': campaign.getId()}) }}">
                        <i class='bx bx-info-circle me-2'></i> 
                        <span>Postes</span>
                     </a>
                    </button>
                    <button 
                        class="btn-action bg-warning" 
                        data-bs-toggle="modal" 
                        data-bs-target="#campaign-{{ campaign.getId() }}"
                    >
                        <i class="bx bx-edit"></i> 
                        <span>Modifier</span>
                    </button>

                    {% if not campaign.isDeleted() %}
                        <button 
                            class="btn-action btn-state bg-danger delete-campaign"
                            data-state="désactiver cette campagne" 
                            data-url="{{ path('admin_campaign_disable', {'id': campaign.getId()}) }}"
                        >
                            <span>Désactiver</span>
                        </button>
                    {% else %}
                        <button 
                            class="btn-action btn-state bg-success delete-campaign"
                            data-state="réactiver cette campagne" 
                            data-url="{{ path('admin_campaign_activate', {'id': campaign.getId()}) }}"
                        >
                            <span>Activer</span>
                        </button>
                    {% endif %}
                </div>
            </td>
            <td><a class='btn btn-warning btn-sm bg-warning text-white w-100' href='#'><i class='bx bx-info-circle me-2'></i>Voir plus</a></td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{# Modal for Adding new item #}
{{ include('back/partials/modals/_newCampaign.html.twig') }}

{# Modals for Editing each items #}
{% for campaignForm in campaignForms %}
    {{ include('back/partials/modals/_editCampaign.html.twig') }}
{% endfor %}